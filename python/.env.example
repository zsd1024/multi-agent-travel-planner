# LLM 配置（默认使用 mock 模式，无需真实 API 即可运行）
LLM_PROVIDER=mock
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-M2.7
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 预算循环最大重试次数
BUDGET_MAX_RETRIES=3

# 并行 Agent 超时（秒）
PARALLEL_TIMEOUT=120

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

LOG_LEVEL=INFO
